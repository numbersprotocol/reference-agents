# ============================================================
# Numbers Protocol Reference Agents - Public Environment
# Copy to .env and fill in your values.
# ============================================================

# REQUIRED: Capture API token.
# Create a token from the Capture developer docs/project console.
CAPTURE_TOKEN=your_capture_token_here

# OPTIONAL: Reddit OAuth for SocialProve.
# If omitted, SocialProve falls back to public Mastodon and Dev.to sources.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# OPTIONAL: Slack alerting for agent failures and monitor summaries.
SLACK_WEBHOOK_URL=

# OPTIONAL: Per-agent rate overrides.
NEWSPROVE_INTERVAL=290
NEWSPROVE_DAILY_CAP=300
SOCIALPROVE_INTERVAL=430
SOCIALPROVE_DAILY_CAP=200

# OPTIONAL: NewsProve screenshot settings.
NEWSPROVE_SCREENSHOT_TIMEOUT=15000
NEWSPROVE_SCREENSHOT_WIDTH=1280
NEWSPROVE_SCREENSHOT_HEIGHT=800

# OPTIONAL: State directory for deduplication files.
STATE_DIR=./state

# OPTIONAL: Log level.
LOG_LEVEL=INFO
